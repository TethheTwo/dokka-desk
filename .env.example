# ============================================================
# DOKKA Desk — Environment Configuration (template)
# ============================================================
# Copy this file to .env and change the values:
#   cp .env.example .env
#
# For quick start, run ./init.sh instead — it generates a .env
# with random secrets automatically.
#
# ADVERTENCIA: En producción, cambia todas las claves por
# valores seguros. No uses los defaults ni los generados
# por init.sh en un entorno expuesto a internet.
# ============================================================

# PostgreSQL
POSTGRES_PASSWORD=CHANGE_ME

# JWT Secret (used by GoTrue and PostgREST)
JWT_SECRET=CHANGE_ME

# Site URL (cambiar a https://dokka-desk.zokaboom.xyz cuando uses Cloudflare Tunnel)
SITE_URL=http://localhost:8080

# Supabase-compatible API keys
# Run ./init.sh to generate proper keys signed with your JWT_SECRET
SUPABASE_PUBLISHABLE_KEY=CHANGE_ME
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME

# Vite (frontend) configuration (debe coincidir con SITE_URL para same-origin)
VITE_SUPABASE_URL=http://localhost:8080
VITE_SUPABASE_PUBLISHABLE_KEY=CHANGE_ME

# Admin credentials (auto-generated by init.sh)
ADMIN_EMAIL=admin@dokkadesk.com
ADMIN_PASSWORD=CHANGE_ME
